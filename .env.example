# ── Email Configuration (Required) ──
# SMTP settings for QQ邮箱 (defaults shown, change if using other providers)
SMTP_HOST=smtp.qq.com
SMTP_PORT=465

# Your QQ email address (sender)
SMTP_USER=123456789@qq.com

# QQ邮箱 SMTP 授权码（不是登录密码！）
# 获取方式：QQ邮箱 → 设置 → 账户 → POP3/IMAP/SMTP服务 → 生成授权码
SMTP_PASS=your_16_digit_auth_code

# 接收摘要的邮箱（可以是同一个 QQ邮箱，或其他任意邮箱）
EMAIL_TO=your_email@example.com

# 发件人显示名称（可选）
EMAIL_FROM_NAME=AI Daily Digest


# ── LLM Enhancement (Optional) ──
# Set these only if you want LLM-powered summaries (adds cost)
# LLM_API_KEY=sk-your-api-key
# LLM_PROVIDER=openai       # or "claude"
